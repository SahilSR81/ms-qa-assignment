		{
			"name": "Events",
			"description": "GET /api/events — Retrieves available events. Requires authentication.",
			"item": [
				{
					"name": "Get Events — Happy Path",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200 OK', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contains events array', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('events');",
									"    pm.expect(jsonData.events).to.be.an('array');",
									"});",
									"",
									"pm.test('Each event has required fields with correct types', function () {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.events.length > 0) {",
									"        var event = jsonData.events[0];",
									"        pm.expect(event).to.have.property('id');",
									"        pm.expect(event).to.have.property('title');",
									"        pm.expect(typeof event.title).to.equal('string');",
									"        pm.expect(event).to.have.property('date');",
									"        pm.expect(event).to.have.property('capacity');",
									"        pm.expect(typeof event.capacity).to.equal('number');",
									"    }",
									"});",
									"",
									"// Capture first event ID for downstream use",
									"var jsonData = pm.response.json();",
									"if (jsonData.events && jsonData.events.length > 0) {",
									"    pm.environment.set('event_id', jsonData.events[0].id);",
									"}",
									"",
									"pm.test('Response time is below 2000ms', function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(2000);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
