									"    pm.response.to.have.status(401);",
									"});",
									"",
									"pm.test('Response contains error field with credential message', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('error');",
									"    pm.expect(jsonData.error).to.equal('Invalid credentials');",
									"});",
									"",
									"pm.test('Response does not leak a token', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.not.have.property('token');",
									"});",
									"",
									"pm.test('Response time is below 2000ms', function () {",
