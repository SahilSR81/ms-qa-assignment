								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/events",
							"host": ["{{base_url}}"],
							"path": ["api", "events"]
						},
						"description": "Fetches the list of available events using a valid token. Captures the first event's ID into `event_id` for event registration."
					},
